{
  "alwaysUpdateLinks": true,
  "pdfExportSettings": {
    "pageSize": "A4",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  },
  "spellcheck": true,
  "spellcheckLanguages": [
    "da",
    "en-GB"
  ],
  "strictLineBreaks": true,
  "newFileLocation": "folder",
  "newFileFolderPath": "/notes",
  "newLinkFormat": "relative",
  "useMarkdownLinks": true,
  "showUnsupportedFiles": true
}