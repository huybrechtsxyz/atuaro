{"key":"foundryvtt-simple-calendar.calendar-configuration","value":"[{\"id\":\"default\",\"name\":\"Martaka\",\"currentDate\":{\"year\":365,\"month\":2,\"day\":2,\"seconds\":21757},\"general\":{\"gameWorldTimeIntegration\":\"self\",\"showClock\":true,\"noteDefaultVisibility\":false,\"postNoteRemindersOnFoundryLoad\":true,\"pf2eSync\":true,\"dateFormat\":{\"date\":\"MMMM DD, YYYY\",\"time\":\"HH:mm:ss\",\"monthYear\":\"MMMM YAYYYYYZ\"},\"compactViewOptions\":{\"controlLayout\":\"quick-increment\"}},\"leapYear\":{\"id\":\"a830efaa\",\"rule\":\"none\",\"customMod\":0},\"months\":[{\"id\":\"fae9cb32\",\"name\":\"Tatea\",\"description\":\"Deep Winter, man is now extremely cold and kindles fires before which he basks. Sunrise at 6h and sunset at 13h. Daylight for 7 hours.\",\"abbreviation\":\"Tatea\",\"numericRepresentation\":1,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":31,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"ee333fee\",\"name\":\"Pepua\",\"description\":\"Deep Winter, man is now extremely cold and kindles fires before which he basks. Sunrise at 6h and sunset at 13h. Daylight for 7 hours.\",\"abbreviation\":\"Pepua\",\"numericRepresentation\":2,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":29,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"40e9ef8b\",\"name\":\"Mahea\",\"description\":\" days\\tEarly spring. The earth has now acquired warmth, as have vegetation and trees. Sunrise at 5h and sunset at 15h. Daylight for 10 hours.\",\"abbreviation\":\"Mahea\",\"numericRepresentation\":3,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":31,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"eadf15b9\",\"name\":\"Paenga\",\"description\":\"Full spring, birds are now sitting in their nests. Sunrise at 4h and sunset at 15h. Daylight for 11 hours.\",\"abbreviation\":\"Paenga\",\"numericRepresentation\":4,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":30,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"86eb4815\",\"name\":\"Harata\",\"description\":\"Late spring, the world has now become quite warm. Sunrise at 3h and sunset at 16h. Daylight for 13 hours.\",\"abbreviation\":\"Harata\",\"numericRepresentation\":5,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":31,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"94a4103b\",\"name\":\"Pipara\",\"description\":\"Early summer, it has now become summer, and the sun has acquired strength. Sunrise at 2h and sunset at 17h. Daylight for 15 hours.\",\"abbreviation\":\"Pipara\",\"numericRepresentation\":6,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":30,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"36fcde00\",\"name\":\"Hikoga\",\"description\":\"High summer, fruits are now ripe, and man eats of the new food of the season.Sunrise at 2h and sunset at 18h. Daylight for 16 hours.\",\"abbreviation\":\"Hikoga\",\"numericRepresentation\":7,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":31,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"3491e327\",\"name\":\"Okoa\",\"description\":\"Late summer, the foot of the summer star now rests upon the world. Sunrise at 2h and sunset at 16h. Daylight for 14 hours.\",\"abbreviation\":\"Okoa\",\"numericRepresentation\":8,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":31,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"787ee91c\",\"name\":\"Mahura\",\"description\":\"Early fall, The crops are now harvested. Sunrise at 3h and sunset at 15h. Daylight for 12 hours.\",\"abbreviation\":\"Mahura\",\"numericRepresentation\":9,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":30,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"c0861f54\",\"name\":\"Noema\",\"description\":\"Late fall, all straw is now stacked at the borders of the plantations. Sunrise at 6h and sunset at 14h. Daylight for 10 hours.\",\"abbreviation\":\"Noema\",\"numericRepresentation\":10,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":31,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null},{\"id\":\"6aa5b4a4\",\"name\":\"Hakiha\",\"description\":\"Early winter, crops are now stored in pits. The tasks of man are finished. Sunrise at 6h and sunset at 14h. Daylight for 8 hours.\",\"abbreviation\":\"Hakiha\",\"numericRepresentation\":11,\"numericRepresentationOffset\":0,\"numberOfDays\":27,\"numberOfLeapYearDays\":30,\"intercalary\":false,\"intercalaryInclude\":false,\"startingWeekday\":null}],\"moons\":[{\"id\":\"a526d1d9\",\"name\":\"Hariki (Winter moon)\",\"cycleLength\":27,\"firstNewMoon\":{\"yearReset\":\"none\",\"yearX\":0,\"year\":0,\"month\":0,\"day\":0},\"phases\":[{\"name\":\"New Moon\",\"length\":1,\"icon\":\"new\",\"singleDay\":true},{\"name\":\"Waxing Crescent\",\"length\":5.75,\"icon\":\"waxing-crescent\",\"singleDay\":false},{\"name\":\"First Quarter\",\"length\":1,\"icon\":\"first-quarter\",\"singleDay\":true},{\"name\":\"Waxing Gibbous\",\"length\":5.75,\"icon\":\"waxing-gibbous\",\"singleDay\":false},{\"name\":\"Full Moon\",\"length\":1,\"icon\":\"full\",\"singleDay\":true},{\"name\":\"Waning Gibbous\",\"length\":5.75,\"icon\":\"waning-gibbous\",\"singleDay\":false},{\"name\":\"Last Quarter\",\"length\":1,\"icon\":\"last-quarter\",\"singleDay\":true},{\"name\":\"Waning Crescent\",\"length\":5.75,\"icon\":\"waning-crescent\",\"singleDay\":false}],\"color\":\"#ffffff\",\"cycleDayAdjust\":0},{\"id\":\"4e8efa43\",\"name\":\"Hikori (Summer moon)\",\"cycleLength\":99,\"firstNewMoon\":