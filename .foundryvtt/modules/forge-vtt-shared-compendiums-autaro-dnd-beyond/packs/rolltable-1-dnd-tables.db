,"drawn":false,"documentCollection":"","documentId":null,"_id":"EXbgOPTzhxAFsYvE"}],"formula":"d10","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677679878028,"modifiedTime":1677679878028,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"BxhwEZbpst0IAAGN"}
{"name":"Sending Stone: Quirks of Your Sending Stone","flags":{"ddbimporter":{"parentName":"Sending Stone","keys":["D8","QUIRK"],"diceKeys":["D8"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"It’s a flip stone.","img":"icons/svg/d20-black.svg","weight":1,"range":[1,1],"drawn":false,"documentCollection":"","documentId":null,"_id":"T7zClRtSkKxjuM2x"},{"flags":{},"type":0,"text":"It gets great reception everywhere except in your headquarters.","img":"icons/svg/d20-black.svg","weight":1,"range":[2,2],"drawn":false,"documentCollection":"","documentId":null,"_id":"OMCRxb7gOE4IH7l6"},{"flags":{},"type":0,"text":"It sometimes picks up other magical conversations.","img":"icons/svg/d20-black.svg","weight":1,"range":[3,3],"drawn":false,"documentCollection":"","documentId":null,"_id":"Wc6XnZwr4VLpOXos"},{"flags":{},"type":0,"text":"It’s the perfect size, shape, and weight to be used as a skipping stone.","img":"icons/svg/d20-black.svg","weight":1,"range":[4,4],"drawn":false,"documentCollection":"","documentId":null,"_id":"6FqI5DygPjaPZGve"},{"flags":{},"type":0,"text":"It heats up when you use it, to the extent that it once burned through your gloves.","img":"icons/svg/d20-black.svg","weight":1,"range":[5,5],"drawn":false,"documentCollection":"","documentId":null,"_id":"50ZG63gDka34EMBq"},{"flags":{},"type":0,"text":"It has an obnoxious ringtone that you can’t work out how to change.","img":"icons/svg/d20-black.svg","weight":1,"range":[6,6],"drawn":false,"documentCollection":"","documentId":null,"_id":"ItEaCbxD0szB5iRU"},{"flags":{},"type":0,"text":"It fails to notify you of incoming messages except for a faint pulsating glow.","img":"icons/svg/d20-black.svg","weight":1,"range":[7,7],"drawn":false,"documentCollection":"","documentId":null,"_id":"RrijgbKqPXGz6SK3"},{"flags":{},"type":0,"text":"It’s voice activated, so that every time you talk to someone, it tries to send a message to someone else.","img":"icons/svg/d20-black.svg","weight":1,"range":[8,8],"drawn":false,"documentCollection":"","documentId":null,"_id":"7gYC9Adc7RJ0xKKS"}],"formula":"","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680286062,"modifiedTime":1677680286062,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"CHyTgBMV8dKFsHL7"}
{"name":"Sword of Zariel: Flaws","flags":{"ddbimporter":{"parentName":"Sword of Zariel","keys":["D6","FLAW"],"diceKeys":["D6"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"I am too quick to judge others.","img":"icons/svg/d20-black.svg","weight":1,"range":[1,1],"drawn":false,"documentCollection":"","documentId":null,"_id":"XNhLavvdvENSF0I8"},{"flags":{},"type":0,"text":"I offer forgiveness too readily.","img":"icons/svg/d20-black.svg","weight":1,"range":[2,2],"drawn":false,"documentCollection":"","documentId":null,"_id":"dPYbChS4OBNENyvp"},{"flags":{},"type":0,"text":"I will sacrifice innocent lives for the greater good.","img":"icons/svg/d20-black.svg","weight":1,"range":[3,3],"drawn":false,"documentCollection":"","documentId":null,"_id":"IFWI48BKJvkfDJ0t"},{"flags":{},"type":0,"text":"Flaw? What flaw? I am flawless. Utter perfection!","img":"icons/svg/d20-black.svg","weight":1,"range":[4,4],"drawn":false,"documentCollection":"","documentId":null,"_id":"DwAeASTvsBuTMVQB"},{"flags":{},"type":0,"text":"I allow nothing to stand in the way of my crusade to eradicate evil from the multiverse.","img":"icons/svg/d20-black.svg","weight":1,"range":[5,5],"drawn":false,"documentCollection":"","documentId":null,"_id":"FkCZtxGeHX2VJj2D"},{"flags":{},"type":0,"text":"I ignore those who do not support my plans, for my calling is higher than all others.","img":"icons/svg/d20-black.svg","weight":1,"range":[6,6],"drawn":false,"documentCollection":"","documentId":null,"_id":"xItwRpV5L66jllCX"}],"formula":"","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680294216,"modifiedTime":1677680294216,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"DGqZONEXrYrvqsUA"}
{"name":"Dodecahedron of Doom: EFFECT","flags":{"ddbimporter":{"parentName":"Dodecahedron of Doom","keys":["D12","EFFECT"],"diceKeys":["D12"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"The dodecahedron explodes and is destroyed. Each creature within 20 feet of the exploding die must make a DC 13 Dexterity saving throw, taking 40 ([[/r 9d8[force] # Force damage]]) damage on a failed save, or half as much damage on a successful one.","img":"icons/svg/d20-black.svg","weight":1,"range":[1,2],"drawn":false,"documentCollection":"","documentId":null,"_id":"pHu4zaFOHPMDyxcb"},{"flags":{},"type":0,"text":"The dodecahedron casts <span class=\"Sans-Serif-Character-Styles_Italic-Sans-Serif\">light</span> on itself. The effect lasts until a creature touches the die.","img":"icons/svg/d20-black.svg","weight":1,"range":[3,4],"drawn":false,"documentCollection":"","documentId":null,"_id":"LQviqz719111oN4J"},{"flags":{},"type":0,"text":"The dodecahedron casts <span class=\"Sans-Serif-Character-Styles_Italic-Sans-Serif\">ray of frost</span> (+5 to hit), targeting a random creature within 60 feet of it that doesn’t have total cover against the attack.","img":"icons/svg/d20-black.svg","weight":1,"range":[5,6],"drawn":false,"documentCollection":"","documentId":null,"_id":"vWn2HYQ5wXMlGYcq"},{"flags":{},"type":0,"text":"The dodecahedron casts <span class=\"Sans-Serif-Character-Styles_Italic-Sans-Serif\">shocking grasp</span> (+5 to hit) on the next creature that touches it.","img":"icons/svg/d20-black.svg","weight":1,"range":[7,8],"drawn":false,"documentCollection":"","documentId":null,"_id":"8g92lWRS96EfjZh3"},{"flags":{},"type":0,"text":"The dodecahedron casts <span class=\"Sans-Serif-Character-Styles_Italic-Sans-Serif\">darkness</span> on itself. The effect has a duration of 10 minutes.","img":"icons/svg/d20-black.svg","weight":1,"range":[9,10],"drawn":false,"documentCollection":"","documentId":null,"_id":"kff5OOQgoEs4gFhz"},{"flags":{},"type":0,"text":"The next creature to touch the dodecahedron gains[[1d10]] ([[/r 1d10]])  temporaryhit points that last for 1 hour.","img":"icons/svg/d20-black.svg","weight":1,"range":[11,12],"drawn":false,"documentCollection":"","documentId":null,"_id":"pX00jrTWIU02QWgZ"}],"formula":"","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680249366,"modifiedTime":1677680249366,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"DsPiAnYRUD1sll0V"}
{"name":"Quaal's Feather Token: Feather Token","flags":{"ddbimporter":{"parentName":"Quaal's Feather Token","keys":["d100","Feather Token"],"diceKeys":["d100"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"Anchor","img":"icons/svg/d20-black.svg","weight":1,"range":[1,20],"drawn":false,"documentCollection":"","documentId":null,"_id":"ssKvMsJjo63tpfkp"},{"flags":{},"type":0,"text":"Bird","img":"icons/svg/d20-black.svg","weight":1,"range":[21,35],"drawn":false,"documentCollection":"","documentId":null,"_id":"SADMQfAUQ5KbgAkq"},{"flags":{},"type":0,"text":"Fan","img":"icons/svg/d20-black.svg","weight":1,"range":[36,50],"drawn":false,"documentCollection":"","documentId":null,"_id":"OQ41eMxsOl2HSkDo"},{"flags":{},"type":0,"text":"Swan Boat","img":"icons/svg/d20-black.svg","weight":1,"range":[51,65],"drawn":false,"documentCollection":"","documentId":null,"_id":"hWrRkJRErUX3p7Vv"},{"flags":{},"type":0,"text":"Tree","img":"icons/svg/d20-black.svg","weight":1,"range":[66,90],"drawn":false,"documentCollection":"","documentId":null,"_id":"V9lsD6XBzFKLlbF3"},{"flags":{},"type":0,"text":"Whip","img":"icons/svg/d20-black.svg","weight":1,"range":[91,100],"drawn":false,"documentCollection":"","documentId":null,"_id":"zQhqFAKKD3SlhYG4"}],"formula":"d100","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680181601,"modifiedTime":1677680181601,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"E2WpeO99K5CKiQNb"}
{"name":"Robe of Useful Items: Patch","flags":{"ddbimporter":{"parentName":"Robe of Useful Items","keys":["d100","Patch"],"diceKeys":["d100"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"Bag of 100 gp","img":"icons/svg/d20-black.svg","weight":1,"range":[1,8],"drawn":false,"documentCollection":"","documentId":null,"_id":"t6LNTKfO4nC5g2Tu"},{"flags":{},"type":0,"text":"Silver coffer (1 foot long, 6 inches wide and deep) worth 500 gp","img":"icons/svg/d20-black.svg","weight":1,"range":[9,15],"drawn":false,"documentCollection":"","documentId":null,"_id":"ImfPUp7DQO0AgYJA"},{"flags":{},"type":0,"text":"Iron door (up to 10 feet wide and 10 feet high, barred on one side of your choice), which you can place in an opening you can reach; it conforms to fit the opening, attaching and hinging itself","img":"icons/svg/d20-black.svg","weight":1,"range":[16,22],"drawn":false,"documentCollection":"","documentId":null,"_id":"rHO89bkZTTvT4M9c"},{"flags":{},"type":0,"text":"10 gems worth 100 gp each","img":"icons/svg/d20-black.svg","weight":1,"range":[23,30],"drawn":false,"documentCollection":"","documentId":null,"_id":"FKb0etCVeGXmw6eq"},{"flags":{},"type":0,"text":"Wooden ladder (24 feet long)","img":"icons/svg/d20-black.svg","weight":1,"range":[31,44],"drawn":false,"documentCollection":"","documentId":null,"_id":"6hX6BcZ8lreBnBmc"},{"flags":{},"type":0,"text":"A riding horse with saddle bags","img":"icons/svg/d20-black.svg","weight":1,"range":[45,51],"drawn":false,"documentCollection":"","documentId":null,"_id":"lJKM1iiwZy7Z43wD"},{"flags":{},"type":0,"text":"Pit (a cube 10 feet on a side), which you can place on the ground within 10 feet of you","img":"icons/svg/d20-black.svg","weight":1,"range":[52,59],"drawn":false,"documentCollection":"","documentId":null,"_id":"uqaSCZltVbxqZJCu"},{"flags":{},"type":0,"text":"Potion of healing (4)","img":"icons/svg/d20-black.svg","weight":1,"range":[60,68],"drawn":false,"documentCollection":"","documentId":null,"_id":"Y0Lw8juVST13vt6p"},{"flags":{},"type":0,"text":"Rowboat (12 feet long)","img":"icons/svg/d20-black.svg","weight":1,"range":[69,75],"drawn":false,"documentCollection":"","documentId":null,"_id":"Z6nWgIHFEZivrU1X"},{"flags":{},"type":0,"text":"Spell scroll containing one spell of 1st to 3rd level","img":"icons/svg/d20-black.svg","weight":1,"range":[76,83],"drawn":false,"documentCollection":"","documentId":null,"_id":"QrWGhaUALBBGNm5J"},{"flags":{},"type":0,"text":"Mastiff (2)","img":"icons/svg/d20-black.svg","weight":1,"range":[84,90],"drawn":false,"documentCollection":"","documentId":null,"_id":"0G44HZxSw9ZW9kl0"},{"flags":{},"type":0,"text":"Window (2 feet by 4 feet, up to 2 feet deep), which you can place on a vertical surface you can reach","img":"icons/svg/d20-black.svg","weight":1,"range":[91,96],"drawn":false,"documentCollection":"","documentId":null,"_id":"ZxHpQw4Z9GhSH3Rd"},{"flags":{},"type":0,"text":"Portable ram","img":"icons/svg/d20-black.svg","weight":1,"range":[97,100],"drawn":false,"documentCollection":"","documentId":null,"_id":"zRBrLVibeUvIQVpi"}],"formula":"d100","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677679753457,"modifiedTime":1677679753457,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"ER97BvrARfx5zXGr"}
{"name":"Pyxis of Pandemonium: CALAMITY","flags":{"ddbimporter":{"parentName":"Pyxis of Pandemonium","keys":["D8","CALAMITY"],"diceKeys":["D8"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"<strong>Androphagia.</strong> Each creature within 60 feet of the vessel must succeed on a DC 17 Wisdom saving throw or go berserk for 1 minute. The berserk creature must begin its turn using the Attack action to make one melee or ranged attack (its choice) against the creature nearest to it. The berserk creature can repeat the save at the end of its turn, ending the effect on itself on a success.","img":"icons/svg/d20-black.svg","weight":1,"range":[1,1],"drawn":false,"documentCollection":"","documentId":null,"_id":"MD7FoFMBt4Y2kVbN"},{"flags":{},"type":0,"text":"<b>Bile Blight.</b> The vessel casts the harm spell on each creature within 30 feet of it.","img":"icons/svg/d20-black.svg","weight":1,"range":[2,2],"drawn":false,"documentCollection":"","documentId":null,"_id":"P6KH3KL926HCGKay"},{"flags":{},"type":0,"text":"<strong>Flood.</strong> The vessel casts the tsunami spell at a point of the DM’s choice within 120 feet of it.","img":"icons/svg/d20-black.svg","weight":1,"range":[3,3],"drawn":false,"documentCollection":"","documentId":null,"_id":"LSR1SBMeN38NYwzk"},{"flags":{},"type":0,"text":"<b>Medusa’s Gaze.</b> The vessel casts the flesh to stone spell on each creature within 30 feet of it.","img":"icons/svg/d20-black.svg","weight":1,"range":[4,4],"drawn":false,"documentCollection":"","documentId":null,"_id":"Wxt9R0LfAOdSPTRF"},{"flags":{},"type":0,"text":"<strong>Labyrinth.</strong> The vessel casts the maze spell on each creature within 30 feet of it.","img":"icons/svg/d20-black.svg","weight":1,"range":[5,5],"drawn":false,"documentCollection":"","documentId":null,"_id":"NXRUovBVVukgY48r"},{"flags":{},"type":0,"text":"<b>Nightmare.</b> Tendrils of shadow seep from the vessel and form into[[1d4]] ([[/r 1d4]])  shadowdemons (see the <span class=\"Sans-Serif-Character-Styles_Italic-Sans-Serif\"><a class=\"sourcebook\" title=\"Monster Manual\" href=\"https://www.dndbeyond.com/sources/mm\">Monster Manual</a></span> for their stat block), which appear in unoccupied spaces within 30 feet of it and are hostile.","img":"icons/svg/d20-black.svg","weight":1,"range":[6,6],"drawn":false,"documentCollection":"","documentId":null,"_id":"ZXhh2xfc1fGkDb3l"},{"flags":{},"type":0,"text":"<strong>Swarming Insects.</strong> The vessel casts the insect plague spell, centered on itself and with a radius of 30 feet.","img":"icons/svg/d20-black.svg","weight":1,"range":[7,7],"drawn":false,"documentCollection":"","documentId":null,"_id":"Two06OXJg7nukUVj"},{"flags":{},"type":0,"text":"<strong>Unbridled Revel.</strong> The vessel casts the Otto's irresistible dance spell on each creature within 30 feet of it.","img":"icons/svg/d20-black.svg","weight":1,"range":[8,8],"drawn":false,"documentCollection":"","documentId":null,"_id":"wdQbXvvatp0J6u4r"}],"formula":"","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680309933,"modifiedTime":1677680309933,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"ETWKrxVAdLU9aPq4"}
{"name":"Sword of Zariel: Ideals","flags":{"ddbimporter":{"parentName":"Sword of Zariel","keys":["D6","IDEAL"],"diceKeys":["D6"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"<span class=\"Sans-Serif-Character-Styles_Bold-Sans-Serif\">Charity.</span> I always help those in need. (Good)","img":"icons/svg/d20-black.svg","weight":1,"range":[1,1],"drawn":false,"documentCollection":"","documentId":null,"_id":"ndTlbQhMRHfeMpik"},{"flags":{},"type":0,"text":"<span class=\"Sans-Serif-Character-Styles_Bold-Sans-Serif\">Faith.</span> I choose to follow the tenets of a particular lawful good deity to the letter. (Lawful)","img":"icons/svg/d20-black.svg","weight":1,"range":[2,2],"drawn":false,"documentCollection":"","documentId":null,"_id":"qWk44TCLzS65Qh5B"},{"flags":{},"type":0,"text":"<span class=\"Sans-Serif-Character-Styles_Bold-Sans-Serif\">Responsibility.</span> It is the duty of the strong to protect the weak. (Lawful)","img":"icons/svg/d20-black.svg","weight":1,"range":[3,3],"drawn":false,"documentCollection":"","documentId":null,"_id":"wleTbv4RGT4F4UsF"},{"flags":{},"type":0,"text":"<span class=\"Sans-Serif-Character-Styles_Bold-Sans-Serif\">Respect.</span> All people deserve to be treated with dignity. (Good)","img":"icons/svg/d20-black.svg","weight":1,"range":[4,4],"drawn":false,"documentCollection":"","documentId":null,"_id":"mxOdPJQH5Gai759c"},{"flags":{},"type":0,"text":"<span class=\"Sans-Serif-Character-Styles_Bold-Sans-Serif\">Honor.</span> The way I conduct myself determines my reward in the afterlife. (Lawful)","img":"icons/svg/d20-black.svg","weight":1,"range":[5,5],"drawn":false,"documentCollection":"","documentId":null,"_id":"wPmPS9gwBuCZIH4T"},{"flags":{},"type":0,"text":"<span class=\"Sans-Serif-Character-Styles_Bold-Sans-Serif\">Redemption.</span> All creatures are capable of change for the better. (Good)","img":"icons/svg/d20-black.svg","weight":1,"range":[6,6],"drawn":false,"documentCollection":"","documentId":null,"_id":"vjietfDGFMddALnF"}],"formula":"","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680294211,"modifiedTime":1677680294211,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"EToHqcB2xh1Z3Zoc"}
