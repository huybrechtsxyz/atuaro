:null,"_id":"VAzsgY5JIuv0XRyI"},{"flags":{},"type":0,"text":"Night hag","img":"icons/svg/d20-black.svg","weight":1,"range":[87,88],"drawn":false,"documentCollection":"","documentId":null,"_id":"bdsRqIVZJqmS3Bwf"},{"flags":{},"type":0,"text":"Nycaloth","img":"icons/svg/d20-black.svg","weight":1,"range":[89,90],"drawn":false,"documentCollection":"","documentId":null,"_id":"VU7GEDECzQqy3vRe"},{"flags":{},"type":0,"text":"Planetar","img":"icons/svg/d20-black.svg","weight":1,"range":[91,91],"drawn":false,"documentCollection":"","documentId":null,"_id":"lLG2d0l9FmIgWAvG"},{"flags":{},"type":0,"text":"Salamander","img":"icons/svg/d20-black.svg","weight":1,"range":[92,93],"drawn":false,"documentCollection":"","documentId":null,"_id":"bkTa48tn00BNxFTL"},{"flags":{},"type":0,"text":"Slaad (any)","img":"icons/svg/d20-black.svg","weight":1,"range":[94,95],"drawn":false,"documentCollection":"","documentId":null,"_id":"RItqMakAT8XK17F4"},{"flags":{},"type":0,"text":"Solar","img":"icons/svg/d20-black.svg","weight":1,"range":[96,96],"drawn":false,"documentCollection":"","documentId":null,"_id":"dKlQr4kyNQ3hIp7d"},{"flags":{},"type":0,"text":"Succubus/incubus","img":"icons/svg/d20-black.svg","weight":1,"range":[97,98],"drawn":false,"documentCollection":"","documentId":null,"_id":"J8MilIUqTAr8Zqd4"},{"flags":{},"type":0,"text":"Ultroloth","img":"icons/svg/d20-black.svg","weight":1,"range":[99,99],"drawn":false,"documentCollection":"","documentId":null,"_id":"KhLcWHXFvcJHbbRL"},{"flags":{},"type":0,"text":"Xorn","img":"icons/svg/d20-black.svg","weight":1,"range":[100,100],"drawn":false,"documentCollection":"","documentId":null,"_id":"CT1QM3Ww87AE00rd"}],"formula":"d100","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677679676170,"modifiedTime":1677679676170,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"0q1q24BL79zd4Ill"}
{"name":"Occultant Abacus: Ways to Read the Kill","flags":{"ddbimporter":{"parentName":"Occultant Abacus","keys":["d6","Reading"],"diceKeys":["d6"]}},"img":"icons/svg/d20-grey.svg","description":"","results":[{"flags":{},"type":0,"text":"Using a tiny bellows to pump one last breath into a corpse.","img":"icons/svg/d20-black.svg","weight":1,"range":[1,1],"drawn":false,"documentCollection":"","documentId":null,"_id":"c9iY3rL2RC83QIy0"},{"flags":{},"type":0,"text":"Reading the entrails with special reading-the-entrails glasses.","img":"icons/svg/d20-black.svg","weight":1,"range":[2,2],"drawn":false,"documentCollection":"","documentId":null,"_id":"FeRLQeiIzdLUenik"},{"flags":{},"type":0,"text":"Burning a small piece of the body and looking for shapes in the smoke.","img":"icons/svg/d20-black.svg","weight":1,"range":[3,3],"drawn":false,"documentCollection":"","documentId":null,"_id":"JaLLT2RQ5gKE33ky"},{"flags":{},"type":0,"text":"A cautious, reasoned, professional guesstimate.","img":"icons/svg/d20-black.svg","weight":1,"range":[4,4],"drawn":false,"documentCollection":"","documentId":null,"_id":"LH7u0gKCsUHSC0hd"},{"flags":{},"type":0,"text":"Careful measurements. The distance between nostrils. The difference between the index finger and the middle finger. The elasticity of the ear lobe.","img":"icons/svg/d20-black.svg","weight":1,"range":[5,5],"drawn":false,"documentCollection":"","documentId":null,"_id":"iRvwx20oH4H6fkfD"},{"flags":{},"type":0,"text":"You take a long, careful look, and then decide based on which fellow franchisee has been nice to you lately.","img":"icons/svg/d20-black.svg","weight":1,"range":[6,6],"drawn":false,"documentCollection":"","documentId":null,"_id":"9R2hgMIEV59C2ugJ"}],"formula":"d6","replacement":true,"displayRoll":true,"ownership":{"default":0,"7zB0QH211uvK7gvA":3},"_stats":{"systemId":"dnd5e","systemVersion":"2.1.5","coreVersion":"10.291","createdTime":1677680284552,"modifiedTime":1677680284552,"lastModifiedBy":"7zB0QH211uvK7gvA"},"folder":null,"sort":0,"_id":"1Vwn0LUANjgCMJdr"}
